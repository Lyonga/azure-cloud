# PROD Environment Terraform Variables
# Copy this file to terraform.tfvars and fill in your actual values.
# CI or your shell should also set:
# export TF_CLOUD_ORGANIZATION="lyonga-org"
# export TF_WORKSPACE="demo-infra-prod"

resource_group_name      = "rg-demo-prod"
function_app_name        = "func-demo-prod-001"
app_service_plan_name    = "asp-demo-prod-001"
storage_account_name     = "stdemoprod001"
location                 = "eastus"
sku_name                 = "P1V2"
storage_replication_type = "GRS"

app_settings = {
  "ENVIRONMENT" = "prod"
}

common_tags = {
  CostCenter = "engineering"
}

enable_shared_storage_messaging = true
shared_storage_account_name     = "stlyongaprodshare01"
shared_storage_account_tier     = "Standard"
shared_storage_replication_type = "GRS"
shared_container_access_type    = "private"
shared_container_names          = ["app-data", "app-archive"]
shared_queue_names              = ["requests", "notifications"]
